Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "x", ",", "zT", ",", "g", ",", "mu", ",", "m", ",", "u", ",", "fXMu", ",",
      "fXZ"}], "]"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"g", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"m", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DUV", "=", "0"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"u", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"m", "^", "2"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "^", "2"}], "-", "x", "+", "1"}], ")"}]}]}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fXMu", "[", 
      RowBox[{"x_", ",", "mu_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"g", "^", "2"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"4", " ", "Pi"}], ")"}], "^", "3"}]}], ")"}], " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"DUV", "+", 
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"mu", "^", "2"}], "/", 
          RowBox[{"u", "[", "x", "]"}]}], "]"}]}], ")"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fXZ", "[", 
      RowBox[{"x_", ",", "zT_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"g", "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"64", " ", 
          RowBox[{"Pi", "^", "3"}]}], ")"}]}], ")"}], " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], " ", 
      RowBox[{"BesselK", "[", 
       RowBox[{"0", ",", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"u", "[", "x", "]"}], " ", 
          RowBox[{"zT", "^", "2"}]}], "]"}]}], "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"fXMu", "[", 
          RowBox[{"x", ",", "mu"}], "]"}], ",", 
         RowBox[{"fXZ", "[", 
          RowBox[{"x", ",", "zT"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<f\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<f(x,\[Mu])\>\"", ",", "\"\<f(x,zT)\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<Comparison:  \[Mu] = \>\"", ",", "mu", 
           ",", "\"\<,  zT = \>\"", ",", "zT"}], "}"}], "]"}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"zT", ",", "0.1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"mu", ",", "0.1", ",", "5"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.990282157737773*^9, 3.9902821584322033`*^9}, {
