    RowBox[{"(", 
     RowBox[{"x", ",", "zT"}], ")"}], " ", "as", " ", "a", " ", "function", " ",
     "of", " ", "x", " ", "for", " ", "fixed", " ", "zT", " ", "values"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
