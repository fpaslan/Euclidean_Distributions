          RowBox[{"u", "[", "x", "]"}], "]"}]}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"g", "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"16", " ", 
          RowBox[{"m", "^", "2"}], " ", 
          RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", "x", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "-", "x", "+", "1"}], ")"}]}]}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"f", "[", "x", "]"}], ",", 
         RowBox[{"fZ", "[", 
          RowBox[{"x", ",", "zT"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
