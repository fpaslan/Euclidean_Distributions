       RowBox[{"PlotLabel", "->", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Comparison at zT = \>\"", ",", "zT"}], "}"}], 
         "]"}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"zT", ",", "0.1", ",", "5"}], "}"}]}], "]"}]}]}]], "Input",
