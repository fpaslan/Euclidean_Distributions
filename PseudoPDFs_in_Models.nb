Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"x", ",", "zT", ",", "g", ",", "m", ",", "u"}], "]"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"choose", " ", "parameter", " ", "values"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"m", "=", "1"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"m", "^", "2"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "-", "x", "+", "1"}], ")"}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fZ", "[", 
     RowBox[{"x_", ",", "zT_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"g", "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"16", " ", 
         RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", "x", " ", 
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"zT", "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"u", "[", "x", "]"}], "]"}]}], ")"}], " ", 
     RowBox[{"BesselK", "[", 
      RowBox[{"1", ",", 
       RowBox[{"zT", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"u", "[", "x", "]"}], "]"}]}]}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"g", "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"16", " ", 
         RowBox[{"m", "^", "2"}], " ", 
         RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", "x", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "^", "2"}], "-", "x", "+", "1"}], ")"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "f", 
    RowBox[{"(", "x", ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<f(x)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "->", "\"\<f(x)\>\""}]}], "]"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "f", 
    RowBox[{"(", 
     RowBox[{"x", ",", "zT"}], ")"}], " ", "as", " ", "a", " ", "function", " ",
     "of", " ", "x", " ", "for", " ", "fixed", " ", "zT", " ", "values"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"fZ", "[", 
       RowBox[{"x", ",", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", 
        RowBox[{"{", 
         RowBox[{"0.2", ",", "0.5", ",", "1", ",", "2"}], "}"}]}], "}"}]}], 
     "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<f(x,zT)\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<zT=0.2\>\"", ",", "\"\<zT=0.5\>\"", ",", "\"\<zT=1\>\"", 
      ",", "\"\<zT=2\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<f(x,zT) for fixed zT\>\""}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
