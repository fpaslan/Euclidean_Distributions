Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"x", ",", "zT", ",", "g", ",", "m", ",", "u"}], "]"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"choose", " ", "parameter", " ", "values"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"m", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"DUV", "=", "0"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mu", "=", "20"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"m", "^", "2"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "-", "x", "+", "1"}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fXMu", "[", 
     RowBox[{"x_", ",", "mu_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"g", "^", "2"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", " ", "Pi"}], ")"}], "^", "3"}]}], ")"}], " ", "x", " ", 
     
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"DUV", "+", 
       RowBox[{"Log", "[", 
        RowBox[{
         RowBox[{"mu", "^", "2"}], "/", 
         RowBox[{"u", "[", "x", "]"}]}], "]"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fXZ", "[", 
     RowBox[{"x_", ",", "zT_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"g", "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"32", " ", 
         RowBox[{"Pi", "^", "3"}]}], ")"}]}], ")"}], " ", "x", " ", 
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], " ", 
     RowBox[{"BesselK", "[", 
      RowBox[{"0", ",", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"u", "[", "x", "]"}], " ", 
         RowBox[{"zT", "^", "2"}]}], "]"}]}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "f", 
    RowBox[{"(", "x", ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
