Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "x", ",", "zT", ",", "g", ",", "m", ",", "u", ",", "fZ", ",", "f"}], 
    "]"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"g", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"m", "=", "1"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"u", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"m", "^", "2"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "^", "2"}], "-", "x", "+", "1"}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fZ", "[", 
      RowBox[{"x_", ",", "zT_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"g", "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"16", " ", 
          RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"zT", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"u", "[", "x", "]"}], "]"}]}], ")"}], " ", 
      RowBox[{"BesselK", "[", 
       RowBox[{"1", ",", 
        RowBox[{"zT", " ", 
